# URL canonique du site (SEO, OG, JSON-LD). Ex. https://effinor.fr
# VITE_SITE_URL=https://effinor.fr

# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon/Public Key
# Get this from your Supabase project settings > API
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Mini-formulaire → public.leads : valeur de l’enum Postgres `lead_source` (doit exister en base)
# VITE_LEAD_SOURCE_MINI_FORM=website
# Pour désactiver l’insert Supabase du mini-form malgré URL/clé :
# VITE_DISABLE_SUPABASE_MINI_FORM_INSERT=true

# --- Airtable (formulaires → leads) ---
# Token avec droit ÉCRITURE — inclus dans le bundle navigateur.
# Scopes requis : data.records:write  |  Accès : votre base uniquement
VITE_AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ID de la base Airtable (commence par "app")
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
# Nom de la table blog (ex: Blog_Articles)
VITE_AIRTABLE_BLOG_TABLE=Blog_Articles
# Table des réalisations / études de cas (défaut : Realisations)
VITE_AIRTABLE_REALISATIONS_TABLE=Realisations

# --- Airtable token READ-ONLY pour la génération du sitemap (build-time uniquement) ---
# ⚠️  Ce token N'est PAS préfixé VITE_ → jamais inclus dans le bundle navigateur.
# Créez un token dédié (lecture seule, accès uniquement à la table Blog) :
#   https://airtable.com/create/tokens
# Scopes requis : data.records:read  |  Accès : table Blog uniquement
# Si absent, le build utilise VITE_AIRTABLE_TOKEN en fallback.
AIRTABLE_BLOG_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Analytics (opt-in : chargé seulement si cookie-consent = accepted) ---
# Google Tag Manager (recommandé) : conteneur type GTM-XXXXXXX
# VITE_GTM_ID=GTM-XXXXXXX
# Google Analytics 4 direct (si pas de GTM) : G-XXXXXXXXXX
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
